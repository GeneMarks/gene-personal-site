{
    "name": "blog.genemarks.net",
    "scripts": {
        "dev": "npm-run-all -p dev:*",
        "build": "npm-run-all -p build:*",
        "dev:11ty": "eleventy --serve",
        "dev:css": "tailwindcss-cli -i ./src/_tailwind/tailwind.css -o ./dist/assets/css/main.css --watch --postcss",
        "build:11ty": "eleventy",
        "build:css": "tailwindcss-cli -i ./src/_tailwind/tailwind.css -o ./dist/assets/css/main.css --postcss"
    },
    "type": "module",
    "devDependencies": {
        "@11ty/eleventy": "^3.1.2",
        "@11ty/eleventy-plugin-rss": "^2.0.4",
        "@shikijs/transformers": "^3.22.0",
        "@tailwindcss/postcss": "^4.1.11",
        "autoprefixer": "^10.4.21",
        "cssnano": "^7.0.7",
        "markdown-it-anchor": "^9.2.0",
        "markdown-it-attrs": "^4.3.1",
        "markdown-it-footnote": "^4.0.0",
        "markdown-it-mark": "^4.0.0",
        "npm-run-all": "^4.1.5",
        "postcss": "^8.5.6",
        "shiki": "^3.22.0",
        "tailwindcss-cli": "^0.1.2"
    }
}
